# Clave de Google AI Studio (https://aistudio.google.com/apikey).
# Copia este archivo como .env.local y pon tu clave. Sin clave, la app
# funciona con el proveedor determinista de demostración.
GEMINI_API_KEY=

# Opcional: modelo a usar (por defecto gemini-3.1-flash-lite).
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Reto 2: landing + formulario de solicitud (Supabase) ---
# URL y service role key de tu proyecto de Supabase. Sin estas dos, el
# formulario de la landing no puede guardar solicitudes ni subir imágenes.
# La service role key SOLO se lee en el servidor (Server Action); nunca la
# expongas en código de cliente. Aplica el esquema con supabase/schema.sql
# (SQL Editor de Supabase) antes de probar el formulario.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Reservada para uso futuro en el cliente (hoy el formulario no llama a
# Supabase desde el navegador; toda la escritura pasa por el servidor).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional: enlace de WhatsApp del negocio para el footer (wa.me/...). No
# hay un número de WhatsApp de negocio confirmado todavía (ver
# docs/challenge-2.md); sin esta variable, el ícono de WhatsApp del footer
# simplemente no se muestra.
NEXT_PUBLIC_WHATSAPP_URL=
