# Clave de Google AI Studio (https://aistudio.google.com/apikey).
# Copia este archivo como .env.local y pon tu clave. Sin clave, la app
# funciona con el proveedor determinista de demostración.
GEMINI_API_KEY=

# Opcional: modelo a usar (por defecto gemini-3.1-flash-lite).
GEMINI_MODEL=gemini-3.1-flash-lite

# --- Reto 2: landing + formulario de solicitud (Supabase) ---
# URL y clave secreta de tu proyecto de Supabase. Sin estas dos, el
# formulario de la landing no puede guardar solicitudes ni subir imágenes.
# Esta clave SOLO se lee en el servidor (Server Action); nunca la expongas
# en código de cliente. Aplica el esquema con supabase/schema.sql (SQL
# Editor de Supabase) antes de probar el formulario.
#
# En Project Settings → API Keys del dashboard: en proyectos nuevos
# aparece como "Secret key" (empieza con sb_secret_...); en proyectos
# más antiguos puede aparecer como "service_role" (un JWT largo). Ambas
# funcionan igual aquí — copia la que veas.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Reservada para uso futuro en el cliente (hoy el formulario no llama a
# Supabase desde el navegador; toda la escritura pasa por el servidor).
# Es la contraparte pública: "Publishable key" (sb_publishable_...) en
# proyectos nuevos, o "anon" en proyectos más antiguos.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional: enlace de WhatsApp del negocio para el footer (wa.me/...). No
# hay un número de WhatsApp de negocio confirmado todavía (ver
# docs/challenge-2.md); sin esta variable, el ícono de WhatsApp del footer
# simplemente no se muestra.
NEXT_PUBLIC_WHATSAPP_URL=

# --- Reto 4: automatización de leads (correo por SMTP de Gmail) ---
# Sin las variables de esta sección, en desarrollo/test el envío de
# correos usa un stub que solo registra en consola (no envía nada real, no
# rompe `npm run dev` ni `npm test`). En producción, si falta cualquiera,
# el paso de correo correspondiente se registra como error en
# lead_automation_events — nunca se simula un envío exitoso.
#
# Valores para la cuenta Gmail exclusiva del negocio:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#   SMTP_USER=<la cuenta Gmail del negocio>
#   EMAIL_FROM=Familia Ponquesito <la misma cuenta Gmail>
# EMAIL_FROM debe corresponder a la misma cuenta autenticada en SMTP_USER
# (Gmail reescribe remitentes ajenos). Todas se leen solo en el servidor.
SMTP_HOST=
SMTP_PORT=

# Opcional: "true" para TLS implícito (SMTPS). Si se omite, se infiere del
# puerto: true solo para 465; otros puertos (587) negocian STARTTLS.
SMTP_SECURE=

SMTP_USER=

# Contraseña de APLICACIÓN de Gmail (https://myaccount.google.com/apppasswords,
# requiere verificación en dos pasos). NUNCA la contraseña normal de la
# cuenta, y NUNCA en un archivo versionado — solo .env.local y Vercel.
SMTP_APP_PASSWORD=

EMAIL_FROM=

# Correo donde Karem recibe la notificación inmediata de cada lead nuevo.
# No hay un correo de negocio confirmado en la base de conocimiento
# todavía (ver src/knowledge/familia-ponquesito.md); mientras tanto, usa
# aquí un correo de pruebas. Nunca subas este valor a un archivo versionado.
KAREM_NOTIFICATION_EMAIL=
